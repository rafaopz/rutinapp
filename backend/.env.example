# --- Base de datos ---
# psycopg 3 driver. Coincide con docker-compose.yml de la raíz.
# Producción (Neon): usa la cadena de Neon con el driver +psycopg, p. ej.:
#   postgresql+psycopg://USER:PASS@ep-xxxx.region.aws.neon.tech/rutinapp?sslmode=require
DATABASE_URL=postgresql+psycopg://rutinapp:rutinapp@localhost:5433/rutinapp

# --- App ---
PROJECT_NAME=RutinApp
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# --- Auth / JWT ---
# Genera uno con: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_genera_una_clave_segura
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ALGORITHM=HS256

# --- CORS (frontend) ---
# CSV de orígenes permitidos, sin barra final. En producción añade tu dominio
# de Vercel, p. ej.: https://rutinapp.vercel.app,http://localhost:5173
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
